<?xml version="1.0" encoding="utf-8"?>
<!--
   Tiltjuk a felhő-backup-ot és a device-to-device transfert.
   Az alkalmazás GPS nyomvonalat, töltési előzményt és Bluetooth MAC címet
   tárol — ezek érzékeny adatok, ne kerüljenek automatikusan a Google felhőbe.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
